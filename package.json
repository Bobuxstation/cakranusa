{
  "name": "cakranusa",
  "version": "1.1.0",
  "description": "The Indonesian city management experience.",
  "homepage": "https://github.com/Bobuxstation/cakranusa",
  "main": "main.js",
  "scripts": {
    "test": "echo \"No test specified\"",
    "start": "electron ."
  },
  "repository": "https://github.com/Bobuxstation/cakranusa",
  "author": "Perintis Interactive",
  "license": "MIT",
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@faker-js/faker": "^10.2.0",
    "electron-updater": "^5.3.0"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.15.3"
  },
  "publish": {
      "provider": "github",
      "releaseType": "release"
    },
  "build": {
    "appId": "com.perintisinteractive.cakranusa",
    "productName": "Cakranusa",
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "files": [
      "**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "ia32",
            "arm64"
          ]
        }
      ],
      "verifyUpdateCodeSignature": false
    },
    "linux": {
      "target": [
        "deb",
        "AppImage",
        "rpm"
      ],
      "maintainer": "Perintis Interactive",
      "category": "Game"
    },
    "mac": {
      "target": [
        "zip",
        "tar.gz"
      ],
      "category": "public.app-category.games"
    }
  }
}
